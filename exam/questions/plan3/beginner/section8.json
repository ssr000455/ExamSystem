      "template": "{\n  \"name\": \"world_preset.modid.custom_preset\",\n  \"icon\": {\"type\": \"minecraft:texture\", \"properties\": {\"texture\": \"minecraft:textures/block/grass_block_side.png\"}},\n  \"dimension_options\": {\n    \"minecraft:overworld\": {\n      \"type\": \"minecraft:dimension_type\",\n      \"generator\": {\n        \"type\": \"minecraft:noise\",\n        \"settings\": \"modid:custom_noise\",\n        \"biome_source\": {\"type\": \"minecraft:fixed\", \"biome\": \"modid:custom_biome\"}\n      }\n    }\n  }\n}",
